# ============================================================
# TumorTrace AI Dashboard - Run from GitHub + Google Colab
# GitHub: https://github.com/odaynasrawi123/TumorTrace
# ============================================================

# ----------------------------
# 1. Install required libraries
# ----------------------------
!pip install -q flask tensorflow opencv-python pandas numpy matplotlib pillow

# ----------------------------
# 2. Mount Google Drive
# ----------------------------
from google.colab import drive, output
drive.mount('/content/drive')

# ----------------------------
# 3. Download app_flask.py from GitHub
# ----------------------------
!wget -O /content/app_flask.py "https://raw.githubusercontent.com/odaynasrawi123/TumorTrace/main/app_flask.py"

# ----------------------------
# 4. Check that app_flask.py was downloaded
# ----------------------------
import os

if os.path.exists("/content/app_flask.py"):
    print("app_flask.py downloaded successfully.")
    print("File size:", os.path.getsize("/content/app_flask.py"), "bytes")
else:
    raise FileNotFoundError("app_flask.py was not downloaded. Check GitHub path.")

# ----------------------------
# 5. Stop old dashboard processes
# ----------------------------
!pkill -f streamlit || true
!pkill -f flask || true
!pkill -f app_flask.py || true

# ----------------------------
# 6. Run Flask dashboard
# ----------------------------
!nohup python /content/app_flask.py > /content/flask_logs.txt 2>&1 &

# ----------------------------
# 7. Wait for server to start
# ----------------------------
import time
time.sleep(8)

# ----------------------------
# 8. Show Flask logs
# ----------------------------
print("Flask logs:")
!tail -30 /content/flask_logs.txt

# ----------------------------
# 9. Create Colab dashboard link
# ----------------------------
dashboard_url = output.eval_js(
    "google.colab.kernel.proxyPort(8501)"
)

print("\n======================================")
print("TumorTrace AI Dashboard URL:")
print(dashboard_url)
print("======================================")

print("""
Instructions:
1. Open the dashboard URL above.
2. Navigate between dashboard pages.
3. Upload X-ray images in Prediction Demo.
4. The dashboard works while this Colab runtime is active.
""")

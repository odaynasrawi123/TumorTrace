# 2. Mount Google Drive
from google.colab import drive, output
drive.mount('/content/drive')

# 3. Download Flask dashboard from GitHub
!wget -O /content/app_flask.py "https://raw.githubusercontent.com/odaynasrawi123/TumorTrace/main/app_flask.py"

# 4. Stop old dashboard process if exists
!pkill -f app_flask.py || true
!pkill -f flask || true

# 5. Run Flask dashboard
!nohup python /content/app_flask.py > /content/flask_logs.txt 2>&1 &

# 6. Wait for server
import time
time.sleep(8)

# 7. Show logs
print("Flask logs:")
!tail -20 /content/flask_logs.txt

# 8. Generate dashboard link
dashboard_url = output.eval_js("google.colab.kernel.proxyPort(8501)")

print("\n======================================")
print("TumorTrace AI Dashboard URL:")
print(dashboard_url)
print("======================================")

print("""
